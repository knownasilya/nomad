{
  "name": "nomad",
  "version": "1.4.0",
  "description": "A peer-to-peer/decentralized web browser",
  "main": "index.js",
  "private": true,
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "postinstall": "patch-package && electron-builder install-app-deps && cd app && npm install",
    "test": "node_modules/.bin/vitest run",
    "typecheck": "tsc --project tsconfig.json",
    "lint": "oxlint app shared",
    "release-version": "standard-version",
    "build": "node scripts/build.js",
    "burnthemall": "node scripts/tasks/burnthemall.js",
    "rebuild": "node scripts/tasks/rebuild.js",
    "prerelease": "npm run build",
    "release": "electron-builder -p onTagOrDraft",
    "pack": "npm run build && electron-builder --mac dir -p never",
    "dist": "npm run build && electron-builder --mac -p never",
    "start": "node scripts/build.js && node scripts/tasks/start-cli.js",
    "watch": "node scripts/watch.js",
    "lint:fix": "oxlint app shared --fix",
    "format": "oxfmt app shared scripts",
    "format:check": "oxfmt --check app shared scripts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knownasilya/nomad.git"
  },
  "author": "Ilya Radchenko",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/knownasilya/nomad/issues"
  },
  "homepage": "https://github.com/knownasilya/nomad#readme",
  "volta": {
    "node": "22.15.0",
    "npm": "10.9.2"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^3.7.1",
    "@types/node": "^25.9.1",
    "electron": "^42.3.0",
    "electron-builder": "^23.0.2",
    "electron-notarize": "^0.3.0",
    "fs-jetpack": "^1.2.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "patch-package": "^8.0.1",
    "pre-commit": "^1.2.2",
    "q": "^1.4.1",
    "standard-version": "^9.3.2",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vitest": "^4.1.7",
    "yargs": "^4.2.0"
  },
  "optionalDependencies": {
    "appdmg": "^0.4.5",
    "rcedit": "^0.5.0"
  },
  "build": {
    "afterPack": "./scripts/afterPackHook.js",
    "afterSign": "./scripts/afterSignHook.js",
    "appId": "com.knownasilya.nomad",
    "asar": false,
    "asarUnpack": [
      "./fg/json-renderer/index.build.js",
      "./fg/syntax-highlighter/index.js",
      "./node_modules/@beaker/dat-legacy-tools/**",
      "./node_modules/sodium-native/**",
      "./node_modules/sodium-javascript/**",
      "./node_modules/winston/**"
    ],
    "copyright": "© 2020, Blue Link Labs",
    "directories": {
      "app": "app",
      "buildResources": "build",
      "output": "dist"
    },
    "npmRebuild": false,
    "protocols": [
      {
        "name": "URL",
        "schemes": [
          "http",
          "https"
        ]
      },
      {
        "name": "hyper",
        "schemes": [
          "hyper"
        ]
      },
      {
        "name": "dat",
        "schemes": [
          "dat"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "appImage": {
      "category": "Network",
      "desktop": {
        "Name": "Nomad",
        "GenericName": "Web Browser",
        "Type": "Application",
        "Terminal": false,
        "MimeType": "text/html;text/xml;application/xhtml+xml;application/xml;application/rss+xml;application/rdf+xml;image/gif;image/jpeg;image/png;x-scheme-handler/http;x-scheme-handler/https;x-scheme-handler/hyper;x-scheme-handler/dat;video/webm;application/x-xpinstall;",
        "Categories": "GNOME;GTK;Network;WebBrowser;"
      }
    },
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "type": "distribution",
      "entitlements": "build/entitlements.plist",
      "entitlementsInherit": "build/entitlements.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "This app requires camera access to record video.",
        "NSMicrophoneUsageDescription": "This app requires microphone access to record audio."
      }
    },
    "publish": {
      "provider": "github"
    }
  }
}
