{
  "name": "nomad",
  "version": "1.2.4",
  "description": "A peer-to-peer/decentralized web browser",
  "main": "index.js",
  "private": true,
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "node_modules/.bin/vitest run",
    "typecheck": "tsc --project tsconfig.json",
    "lint": "eslint --ignore-pattern 'color-thief.js' --ignore-pattern 'app/node_modules' --ignore-pattern 'app/userland' --ignore-pattern 'vendor' --ignore-pattern '*.build.js' --ignore-pattern 'assets' app",
    "release-version": "standard-version"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knownasilya/nomad.git"
  },
  "author": "Ilya Radchenko",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/knownasilya/nomad/issues"
  },
  "homepage": "https://github.com/knownasilya/nomad#readme",
  "volta": {
    "node": "22.15.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "electron": "^42.3.0",
    "eslint": "^8.12.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.0.0",
    "standard-version": "^9.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
