{
  "name": "beakerbrowser",
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^42.3.0",
    "electron-builder": "^23.0.2",
    "electron-notarize": "^0.3.0",
    "eslint": "^4.5.0",
    "eslint-plugin-import": "^2.7.0",
    "eslint-plugin-node": "^5.1.1",
    "eslint-plugin-promise": "^3.5.0",
    "fs-jetpack": "^1.2.0",
    "pre-commit": "^1.2.2",
    "q": "^1.4.1",
    "rollup": "^1.23.0",
    "vite": "^6.0.0",
    "vite-plugin-node-polyfills": "^0.28.0",
    "yargs": "^4.2.0"
  },
  "optionalDependencies": {
    "appdmg": "^0.4.5",
    "rcedit": "^0.5.0"
  },
  "build": {
    "afterSign": "./afterSignHook.js",
    "appId": "com.bluelinklabs.beaker-browser",
    "asar": false,
    "asarUnpack": [
      "./fg/json-renderer/index.build.js",
      "./fg/syntax-highlighter/index.js",
      "./node_modules/@beaker/dat-legacy-tools/**",
      "./node_modules/sodium-native/**",
      "./node_modules/hyperdrive-daemon/**"
    ],
    "copyright": "© 2020, Blue Link Labs",
    "directories": {
      "app": "../app",
      "buildResources": "../build",
      "output": "../dist"
    },
    "npmRebuild": false,
    "protocols": [
      {
        "name": "URL",
        "schemes": [
          "http",
          "https"
        ]
      },
      {
        "name": "hyper",
        "schemes": [
          "hyper"
        ]
      },
      {
        "name": "dat",
        "schemes": [
          "dat"
        ]
      }
    ],
    "appImage": {
      "category": "Network",
      "desktop": {
        "Name": "Nomad",
        "GenericName": "Web Browser",
        "Type": "Application",
        "Terminal": false,
        "MimeType": "text/html;text/xml;application/xhtml+xml;application/xml;application/rss+xml;application/rdf+xml;image/gif;image/jpeg;image/png;x-scheme-handler/http;x-scheme-handler/https;x-scheme-handler/hyper;x-scheme-handler/dat;video/webm;application/x-xpinstall;",
        "Categories": "GNOME;GTK;Network;WebBrowser;"
      }
    },
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "type": "distribution",
      "entitlements": "../build/entitlements.plist",
      "entitlementsInherit": "../build/entitlements.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "This app requires camera access to record video.",
        "NSMicrophoneUsageDescription": "This app requires microphone access to record audio."
      }
    },
    "publish": {
      "provider": "github"
    }
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps && cd ../app && npm install && cd bg/dat/converter && npm install",
    "build": "node build.js",
    "burnthemall": "node ./tasks/burnthemall.js",
    "lint": "eslint --ignore-pattern 'color-thief.js' --ignore-pattern 'app/node_modules' --ignore-pattern 'vendor' --ignore-pattern '*.build.js' --ignore-pattern 'assets' --fix app",
    "rebuild": "node tasks/rebuild.js",
    "prerelease": "npm run build",
    "release": "electron-builder -p onTagOrDraft",
    "start": "node build.js && node tasks/start-cli.js",
    "watch": "node watch.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/knownasilya/nomad"
  },
  "bugs": {
    "url": "https://github.com/knownasilya/nomad/issues"
  },
  "dependencies": {},
  "volta": {
    "extends": "../package.json"
  }
}
